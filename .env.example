# DigiVault Environment Variables

# Admin email for initial admin account (default: admin@digirift.de)
ADMIN_EMAIL=admin@digirift.de

# REQUIRED: Admin password for initial admin account
ADMIN_PASSWORD=

# REQUIRED in production: Secret for session signing (min 32 chars)
SESSION_SECRET=

# Server port (default: 3000)
PORT=3000

# Node environment (production/development)
NODE_ENV=production
